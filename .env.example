OPENAI_API_KEY=sk-proj_sua_chave_aqui
OPENAI_MODEL=gpt-4o
NUTRIFLOW_API_PORT=8787
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend (vao para o navegador — a anon key e PUBLICA por design, protegida por RLS):
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_key_aqui

# SOMENTE no servidor — NUNCA prefixar com VITE_ nem usar no frontend.
# Esta chave ignora o RLS (acesso total). Mantenha-a apenas no .env (gitignored).
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui
